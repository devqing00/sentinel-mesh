'use client';

import { useState, useEffect, useRef, useCallback } from 'react';
import Link from 'next/link';
import { useWebSocketData } from '@/context/WebSocketContext';

const API = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8000';
const DEVICE_ID = 'WATCH_001';
const PROXIMITIES = ['very close', 'close', 'moderate'] as const;
type Proximity = typeof PROXIMITIES[number];

const PROX_DOT: Record<Proximity, string> = {
  'very close': 'bg-red-400',
  'close':      'bg-orange-400',
  'moderate':   'bg-yellow-400',
};
const PROX_TEXT: Record<Proximity, string> = {
  'very close': 'text-red-400',
  'close':      'text-orange-400',
  'moderate':   'text-yellow-400',
};

interface NearbyContact {
  user_id:   string;
  proximity: Proximity;
  rssi:      number;
}

const RING_R    = 85;
const RING_CIRC = 2 * Math.PI * RING_R;
const SPARK_W   = 260;
const SPARK_H   = 52;

export default function SimulatorPage() {
  const { isLiveMode, setIsLiveMode } = useWebSocketData();
  const [isRunning,  setIsRunning]  = useState(isLiveMode);
  const [isSpiking,  setIsSpiking]  = useState(false);
  const [beating,    setBeating]    = useState(false);

  // Vitals
  const [hr,      setHr]      = useState(72);
  const [temp,    setTemp]    = useState(36.8);
  const [spo2,    setSpo2]    = useState(98);
  const [steps,   setSteps]   = useState(1247);
  const [battery, setBattery] = useState(87);

  // HR history for sparkline (last 30 ticks)
  const [hrHistory, setHrHistory] = useState<number[]>(Array(30).fill(72));

  // Bluetooth contacts
  const [contacts,    setContacts]    = useState<NearbyContact[]>([]);
  const [allUserIds,  setAllUserIds]  = useState<string[]>([]);


  // Ping state
  const [pingLog,    setPingLog]    = useState<string[]>([]);
  const [pingStatus, setPingStatus] = useState<'idle' | 'sending' | 'ok' | 'error'>('idle');
  const [totalPings, setTotalPings] = useState(0);

  // Backend analysis result from last ping response
  const [backendAnalysis, setBackendAnalysis] = useState<{
    risk_tier: string;
    is_anomaly: boolean;
    dual_anomaly: boolean;
    alert_severity: string;
    cluster: string;
    nearby_contacts_registered: number;
  } | null>(null);

  // Spike countdown
  const [spikeLeft, setSpikeLeft] = useState(0);

  // Clock
  const [clockTime, setClockTime] = useState('');

  // Refs so intervals always read the latest value
  const isSpikingRef  = useRef(false);
  const hrRef         = useRef(72);
  const tempRef       = useRef(36.8);
  const spo2Ref       = useRef(98);
  const stepsRef      = useRef(1247);
  const contactsRef   = useRef<NearbyContact[]>([]);

  useEffect(() => { isSpikingRef.current = isSpiking; }, [isSpiking]);
  useEffect(() => { hrRef.current = hr; },               [hr]);
  useEffect(() => { tempRef.current = temp; },           [temp]);
  useEffect(() => { spo2Ref.current = spo2; },           [spo2]);
  useEffect(() => { stepsRef.current = steps; },         [steps]);
  useEffect(() => { contactsRef.current = contacts; },   [contacts]);

  // ── Clock ────────────────────────────────────────────────────────────────────
  useEffect(() => {
    const tick = () =>
      setClockTime(new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
    tick();
    const id = setInterval(tick, 1000);
    return () => clearInterval(id);
  }, []);

  // ── Fetch real user IDs for bluetooth contacts ────────────────────────────
  useEffect(() => {
    // For this environment, we just statically load the real baseline users
    // so we don't accidentally bloat the db with fake UIDs
    const realUsers = Array.from({ length: 50 }, (_, i) => `U${String(i + 1).padStart(3, '0')}`);
    setAllUserIds(realUsers);
  }, []);

  // ── Vitals simulation tick (1 s) ─────────────────────────────────────────
  useEffect(() => {
    if (!isRunning) return;
    const id = setInterval(() => {
      const spiking = isSpikingRef.current;

      setHr(prev => {
        const target = spiking ? 132 : 72;
        const noise  = (Math.random() - 0.5) * (spiking ? 10 : 5);
        const next   = Math.round(Math.max(45, Math.min(185, prev + (target - prev) * 0.18 + noise)));
        hrRef.current = next;
        return next;
      });
      setTemp(prev => {
        const target = spiking ? 39.3 : 36.8;
        const noise  = (Math.random() - 0.5) * 0.09;
        const next   = Math.round(Math.max(35, Math.min(42, prev + (target - prev) * 0.08 + noise)) * 10) / 10;
        tempRef.current = next;
        return next;
      });
      setSpo2(prev => {
        const target = spiking ? 91 : 98;
        const noise  = (Math.random() - 0.5) * 0.6;
        const next   = Math.round(Math.max(85, Math.min(100, prev + (target - prev) * 0.1 + noise)));
        spo2Ref.current = next;
        return next;
      });
      setSteps(prev => {
        const next = prev + Math.floor(Math.random() * 3);
        stepsRef.current = next;
        return next;
      });
      setBattery(prev => Math.max(5, +(prev - 0.008).toFixed(3)));
      setHrHistory(prev => [...prev.slice(-29), hrRef.current]);
    }, 1000);
    return () => clearInterval(id);
  }, [isRunning]);

  // ── Heartbeat animation (rAF loop synced to HR) ───────────────────────────
  useEffect(() => {
    if (!isRunning) { 
      const t = setTimeout(() => setBeating(false), 0);
      return () => clearTimeout(t); 
    }
    let raf: number;
    let lastBeat = performance.now();
    const tick = (now: number) => {
      const beatMs = (60 / Math.max(30, hrRef.current)) * 1000;
      if (now - lastBeat >= beatMs) {
        lastBeat = now;
        setBeating(true);
        setTimeout(() => setBeating(false), 180);
      }
      raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(raf);
  }, [isRunning]);

  // ── Spike countdown ───────────────────────────────────────────────────────
  useEffect(() => {
    let id: ReturnType<typeof setInterval>;
    if (!isSpiking) { 
      const t = setTimeout(() => setSpikeLeft(0), 0); 
      return () => clearTimeout(t); 
    }
    const t2 = setTimeout(() => setSpikeLeft(45), 0);
    id = setInterval(() => {
      setSpikeLeft(prev => {
        if (prev <= 1) { clearInterval(id); setIsSpiking(false); return 0; }
        return prev - 1;
      });
    }, 1000);
    return () => { clearTimeout(t2); clearInterval(id); };
  }, [isSpiking]);

  // ── Randomize bluetooth contacts (every 15-30 s) ──────────────────────────
  const randomizeContacts = useCallback(() => {
    if (allUserIds.length === 0) return;
    const count     = Math.floor(Math.random() * 4) + 1;
    const shuffled  = [...allUserIds].sort(() => Math.random() - 0.5).slice(0, count);
    const next: NearbyContact[] = shuffled.map(uid => ({
      user_id:   uid,
      proximity: PROXIMITIES[Math.floor(Math.random() * PROXIMITIES.length)],
      rssi:      Math.round(-90 + Math.random() * 55),
    }));
    setContacts(next);
    contactsRef.current = next;
  }, [allUserIds]);

  useEffect(() => {
    if (!isRunning || allUserIds.length === 0) return;
    const t = setTimeout(() => randomizeContacts(), 0);
    const interval = 13000 + Math.random() * 17000;
    const id = setInterval(randomizeContacts, interval);
    return () => { clearTimeout(t); clearInterval(id); };
  }, [isRunning, allUserIds, randomizeContacts]);

  // ── Ping backend every 3 s ────────────────────────────────────────────────
  useEffect(() => {
    if (!isRunning) return;
    const id = setInterval(async () => {
      setPingStatus('sending');
      try {
        const res = await fetch(`${API}/api/device/ping`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            user_id:         DEVICE_ID,
            heart_rate:      hrRef.current,
            temperature:     tempRef.current,
            spo2:            spo2Ref.current,
            steps:           stepsRef.current,
            nearby_contacts: contactsRef.current.map(c => c.user_id),
          }),
        });
        if (res.ok) {
          const data = await res.json();
          setPingStatus('ok');
          setTotalPings(p => p + 1);
          if (data.analysis) {
            setBackendAnalysis(data.analysis);
            setPingLog(prev => [
              `${new Date().toLocaleTimeString()}  ${data.analysis.risk_tier}${data.analysis.is_anomaly ? ' ⚠' : ''}  HR:${hrRef.current}bpm  T:${tempRef.current}°C  [${data.analysis.nearby_contacts_registered} contacts]`,
              ...prev,
            ].slice(0, 6));
          }
        } else {
          setPingStatus('error');
        }
      } catch {
        setPingStatus('error');
      }
      setTimeout(() => setPingStatus(s => s !== 'idle' ? 'idle' : s), 2200);
    }, 3000);
    return () => clearInterval(id);
  }, [isRunning]);

  // ── Derived display values ────────────────────────────────────────────────
  const hrZone     = hr > 110 ? 'danger' : hr > 88 ? 'elevated' : 'normal';
  const ringColor  = hrZone === 'danger' ? '#ef4444' : hrZone === 'elevated' ? '#f59e0b' : '#22c55e';
  const hrClass    = hrZone === 'danger' ? 'text-red-400'  : hrZone === 'elevated' ? 'text-amber-400' : 'text-green-400';
  const tempClass  = temp > 38.5  ? 'text-red-400'  : temp > 37.5  ? 'text-orange-400' : 'text-cyan-400';
  const spo2Class  = spo2 < 94    ? 'text-red-400'  : spo2 < 97   ? 'text-amber-400'  : 'text-blue-400';

  // SVG ring progress (40–185 bpm range)
  const hrPct     = Math.min(1, Math.max(0, (hr - 40) / 145));
  const ringOffset = RING_CIRC * (1 - hrPct);

  // Sparkline path
  const sparkPath = hrHistory.length > 1
    ? hrHistory.map((v, i) => {
        const x = (i / (hrHistory.length - 1)) * SPARK_W;
        const y = SPARK_H - ((Math.min(185, Math.max(40, v)) - 40) / 145) * SPARK_H;
        return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
      }).join(' ')
    : '';

  const handleToggle = () => {
    const nextMode = !isRunning;
    setIsRunning(nextMode);
    setIsLiveMode(nextMode);
    if (nextMode) {
      setTotalPings(0); setPingLog([]);
    } else {
      setIsSpiking(false); setContacts([]);
    }
  };

  return (
    <div className="h-full flex flex-col bg-transparent overflow-hidden text-gray-900">
      {/* ── Header ──────────────────────────────────────────────────────────── */}
      <header className="sticky top-0 z-30 bg-white/80 backdrop-blur-md border-b border-border/40 shadow-lg flex-shrink-0">
        <div className="flex items-center gap-4">
          <Link
            href="/"
            className="flex items-center gap-1.5 text-gray-400 hover:text-white text-sm transition-colors"
          >
            <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Dashboard
          </Link>
          <div className="w-px h-3.5 bg-gray-300" />
          <div className="flex items-center gap-1.5 text-gray-900 font-bold text-sm">
            <svg className="w-4 h-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17 1H7c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-2-2-2zm-5 20c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm5-4H7V4h10v13z"/>
            </svg>
            <div>Device Simulator</div>
          </div>
        </div>
      </header>

      {/* ── Main Layout ─────────────────────────────────────────────────────── */}
      <div className="flex-1 flex flex-wrap items-start justify-center gap-8 p-8 overflow-y-auto scrollbar-none relative">
        {/* Decorative elements behind */}
        <div className="absolute top-0 right-0 w-64 h-64 bg-blue-300/20 rounded-full blur-[80px] pointer-events-none" />
        <div className="absolute bottom-0 left-0 w-72 h-72 bg-emerald-200/20 rounded-full blur-[80px] pointer-events-none" />

        {/* ── Phone Shell ─────────────────────────────────────────────────────── */}
        <div className="relative w-[360px] h-[760px] bg-gray-100 rounded-[3.5rem] shadow-[0_0_0_1px_rgba(0,0,0,0.05),0_20px_40px_-10px_rgba(0,0,0,0.1),0_0_50px_rgba(0,0,0,0.05)] border-[8px] border-white p-1 flex-shrink-0 z-10">
          {/* Side Buttons */}
          <div className="absolute -left-[11px] top-[120px] w-[3px] h-8 bg-gray-300 rounded-l-full" />
          <div className="absolute -left-[11px] top-[170px] w-[3px] h-12 bg-gray-300 rounded-l-full" />
          <div className="absolute -left-[11px] top-[230px] w-[3px] h-12 bg-gray-300 rounded-l-full" />
          <div className="absolute -right-[11px] top-[190px] w-[3px] h-16 bg-gray-300 rounded-r-full" />

          {/* Inner Screen */}
          <div className="w-full h-full bg-gray-50 rounded-[3rem] overflow-hidden flex flex-col relative shadow-inner ring-1 ring-black/5">
            {/* Dynamic Island */}
            <div className="absolute top-3 left-1/2 -translate-x-1/2 w-[120px] h-[32px] bg-black rounded-full z-40 flex items-center justify-between px-3 shadow-[inset_0_-2px_4px_rgba(255,255,255,0.1)]">
              <div className="w-2.5 h-2.5 rounded-full bg-[#0a0a0a] ring-1 ring-white/10" />
              {isRunning && (
                <div className="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse shadow-[0_0_5px_rgba(34,197,94,0.6)]" />
              )}
            </div>
            {/* Status Bar */}
            <div className="h-12 pt-2 flex items-start justify-between px-6 text-[11px] font-bold text-gray-900 bg-white/50 backdrop-blur-md z-30">
                <span className="mt-1">{clockTime}</span>
                <div className="flex items-center gap-1.5 mt-1">
                  {/* Signal */}
                  <svg className="w-3.5 h-3.5 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M2 22h20V2L2 22zm18-2H6.83L20 6.83V20z"/>
                  </svg>
                  {/* WiFi */}
                  <svg className="w-3.5 h-3.5 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.01 21.49L23.64 7c-.45-.34-4.93-4-11.64-4C5.28 3 .81 6.66.36 7l11.63 14.49.01.01.01-.01z"/>
                  </svg>
                  <span className="text-gray-500 text-[10px] tabular-nums">{Math.floor(battery)}%</span>
                  {/* Battery */}
                  <div className="flex items-center">
                    <div className="w-6 h-3 border border-gray-600 rounded-sm relative overflow-hidden">
                      <div
                        className={`absolute inset-[1.5px] rounded-[1px] transition-all duration-500 ${battery > 30 ? 'bg-green-400' : 'bg-red-500'}`}
                        style={{ width: `${Math.max(3, battery - 4)}%` }}
                      />
                    </div>
                    <div className="w-[2px] h-2 bg-gray-600 ml-[1px] rounded-r-sm" />
                  </div>
                </div>
              </div>

              {/* App header */}
              <div className="px-5 pt-2 pb-2 flex items-center justify-between flex-shrink-0">
                <div>
                  <div className="text-white font-bold text-sm leading-tight">Health Monitor</div>
                  <div className="text-gray-600 text-[10px]">{DEVICE_ID} · Sentinel Mesh</div>
                </div>
                <div className={`w-9 h-9 rounded-full flex items-center justify-center transition-all ${isSpiking ? 'bg-red-500/25' : isRunning ? 'bg-green-500/15' : 'bg-gray-900'}`}>
                  <svg
                    className={`w-5 h-5 transition-colors duration-300 ${isSpiking ? 'text-red-400' : isRunning ? 'text-green-400' : 'text-gray-700'}`}
                    fill="currentColor" viewBox="0 0 24 24"
                  >
                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                  </svg>
                </div>
              </div>

              {/* ── Watch face ── */}
              <div className="flex justify-center py-3 flex-shrink-0">
                <div className="relative" style={{ width: 196, height: 196 }}>
                  {/* Outer glow */}
                  <div
                    className="absolute inset-0 rounded-full transition-all duration-1000"
                    style={{ boxShadow: isRunning ? `0 0 40px ${ringColor}30` : 'none' }}
                  />

                  {/* SVG ring progress */}
                  <svg className="w-full h-full -rotate-90">
                    <circle cx="100" cy="100" r={RING_R} fill="none" stroke="#e5e7eb" strokeWidth="11" />
                    <circle
                      cx="100" cy="100" r={RING_R}
                      fill="none"
                      stroke={isRunning ? ringColor : '#1f2937'}
                      strokeWidth="11"
                      strokeLinecap="round"
                      strokeDasharray={RING_CIRC}
                      strokeDashoffset={isRunning ? ringOffset : RING_CIRC * 0.85}
                      transform="rotate(-90 100 100)"
                      style={{ transition: 'stroke-dashoffset 0.55s ease, stroke 0.6s ease' }}
                    />
                    {/* Beat pulse ring */}
                    {isRunning && beating && (
                      <circle
                        cx="100" cy="100" r={RING_R + 7}
                        fill="none"
                        stroke={ringColor}
                        strokeWidth="2.5"
                        opacity={0.35}
                      />
                    )}
                  </svg>

                  {/* Face content */}
                  <div className="absolute inset-3 rounded-full bg-gray-950 flex flex-col items-center justify-center">
                    {/* Time */}
                    <div className="text-gray-700 text-[10px] font-medium tabular-nums mb-0.5">{clockTime}</div>

                    {/* Heart + HR number */}
                    <div className="flex items-end gap-1 mb-0.5">
                      <svg
                        className={`w-4 h-4 transition-transform duration-100 ${beating ? 'scale-[1.3]' : 'scale-100'}`}
                        fill={isRunning ? ringColor : '#374151'}
                        viewBox="0 0 24 24"
                      >
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                      </svg>
                      <span className={`text-[2.5rem] font-black tabular-nums leading-none transition-colors duration-300 ${isRunning ? hrClass : 'text-gray-700'}`}>
                        {Math.round(hr)}
                      </span>
                    </div>
                    <div className="text-gray-700 text-[9px] font-bold tracking-[0.18em] mb-2.5">BPM</div>

                    {/* Temp + SpO2 */}
                    <div className="flex gap-5">
                      <div className="text-center">
                        <div className={`text-[11px] font-bold tabular-nums transition-colors ${isRunning ? tempClass : 'text-gray-700'}`}>{temp.toFixed(1)}°</div>
                        <div className="text-gray-800 text-[8px] tracking-widest">TEMP</div>
                      </div>
                      <div className="mt-4 text-center">
                <div className="text-2xl font-bold font-mono tracking-wider text-gray-900">
                  {vitals.heartbeat}<span className="text-xs text-gray-500 ml-1">BPM</span>
                </div>
                <div className="text-[10px] text-gray-500 font-medium uppercase tracking-widest mt-1">
                  Active Monitoring
                </div>
              </div>       {/* Steps */}
                    <div className="text-gray-800 text-[8px] mt-1.5 tabular-nums">{steps.toLocaleString()} steps</div>
                  </div>
                </div>
              </div>

              {/* GPS Target */}
              <div className="premium-card p-4 flex flex-col gap-2 border-blue-50">
                <div className="flex items-center justify-between">
                  <div className="text-xs text-gray-500 font-medium">Current Location</div>
                  <div className="text-[10px] px-1.5 py-0.5 bg-blue-50 text-blue-700 rounded font-bold border border-blue-100">
                    {gpsTarget ? 'MANUAL' : 'AUTO'}
                  </div>
                </div>    <path d="M17.71 7.71L12 2h-1v7.59L6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 11 14.41V22h1l5.71-5.71-4.3-4.29 4.3-4.29zM13 5.83l1.88 1.88L13 9.59V5.83zm1.88 10.46L13 18.17v-3.76l1.88 1.88z"/>
                  </svg>
                  <span className={`text-[10px] font-bold tracking-widest transition-colors ${isRunning ? 'text-blue-400' : 'text-gray-700'}`}>
                    BLUETOOTH {isRunning ? 'ON' : 'OFF'}
                  </span>
                  {isRunning && contacts.length > 0 && (
                    <span className="ml-auto text-[9px] text-gray-600 bg-gray-800 rounded-full px-2 py-0.5">
                      {contacts.length} nearby
                    </span>
                  )}
                </div>
                {isRunning && contacts.length > 0 ? (
                  <div className="space-y-1.5">
                    {contacts.map((c, i) => (
                      <div key={i} className="flex items-center gap-2">
                        <div className={`w-1.5 h-1.5 rounded-full flex-shrink-0 animate-pulse ${PROX_DOT[c.proximity]}`} />
                        <span className="text-gray-400 text-[10px] font-mono flex-1 truncate">{c.user_id}</span>
                        <span className={`text-[9px] font-semibold ${PROX_TEXT[c.proximity]}`}>{c.proximity}</span>
                        <span className="text-gray-700 text-[9px] tabular-nums">{c.rssi}dBm</span>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div className="text-gray-700 text-[9px] text-center py-0.5">
                    {isRunning ? 'Scanning for nearby devices…' : 'Start simulation to scan'}
                  </div>
                )}
              </div>

              {/* ── Control buttons ── */}
              <div className="px-4 flex gap-3 mb-3 flex-shrink-0 mt-2">
                <div className="flex-1 bg-white border border-gray-200 rounded-2xl p-3 shadow-sm flex items-center justify-between">
                  <div className="flex flex-col">
                    <span className="text-xs font-bold text-gray-900">Live Mode</span>
                    <span className="text-[9px] text-gray-500">Syncs to dashboard</span>
                  </div>
                  <button
                    onClick={handleToggle}
                    className={`relative w-11 h-6 rounded-full transition-colors duration-300 ${isRunning ? 'bg-green-500' : 'bg-gray-200'}`}
                  >
                    <div className={`absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow transition-transform duration-300 ${isRunning ? 'translate-x-5' : 'translate-x-0'}`} />
                  </button>
                </div>
                <button
                  onClick={() => { if (!isSpiking) setIsSpiking(true); }}
                  disabled={!isRunning || isSpiking}
                  className={`flex-1 py-3 rounded-2xl text-xs font-bold transition-all duration-200 flex flex-col items-center justify-center ${
                    isSpiking
                      ? 'bg-orange-50 text-orange-400 cursor-default border border-orange-200'
                      : 'bg-orange-600 hover:bg-orange-500 text-white shadow-lg shadow-orange-900/20 disabled:bg-gray-100 disabled:text-gray-400 disabled:shadow-none'
                  }`}
                >
                  <span className="text-sm leading-none mb-0.5">{isSpiking ? '⚡' : '⚡'}</span>
                  <span>{isSpiking ? `${spikeLeft}s` : 'Spike HR'}</span>
                </button>
              </div>

              {/* ── Ping status indicator ── */}
              <div className="px-4 pb-1 flex-shrink-0">
                <div className={`flex items-center gap-2 rounded-xl px-3 py-2 text-[10px] font-medium transition-all ${
                  pingStatus === 'sending' ? 'bg-blue-950/80  border border-blue-900  text-blue-300'  :
                  pingStatus === 'ok'      ? 'bg-green-950/80 border border-green-900 text-green-300' :
                  pingStatus === 'error'   ? 'bg-red-950/80   border border-red-900   text-red-300'   :
                  'bg-gray-900 border border-gray-800 text-gray-600'
                }`}>
                  <div className={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${
                    pingStatus === 'sending' ? 'bg-blue-400  animate-pulse' :
                    pingStatus === 'ok'      ? 'bg-green-400' :
                    pingStatus === 'error'   ? 'bg-red-400'  :
                    'bg-gray-700'
                  }`} />
                  <span className="truncate">
                    {pingStatus === 'sending' && '📡 Transmitting to Sentinel Mesh…'}
                    {pingStatus === 'ok'      && `✓ Delivered — ${totalPings} total pings`}
                    {pingStatus === 'error'   && '✗ Backend unreachable — start uvicorn'}
                    {pingStatus === 'idle'    && (isRunning ? `Next ping in ~3s · ${totalPings} sent` : 'Simulation stopped')}
                  </span>
                </div>
              </div>

              {/* Home indicator */}
              <div className="flex justify-center py-3 mt-auto">
                <div className="w-24 h-1 bg-gray-800 rounded-full" />
              </div>
            </div>
          </div>
        </div>

        {/* ════════════════════ Monitoring panel ════════════════════ */}
        <div className="flex-1 min-w-[280px] max-w-md space-y-4">

          {/* Vitals grid */}
          <div>
            <div className="text-gray-500 text-[10px] font-bold uppercase tracking-widest mb-2">Live Vitals</div>
            <div className="grid grid-cols-2 gap-2.5">
              {[
                {
                  label: 'Heart Rate', value: `${Math.round(hr)}`, unit: 'BPM',
                  color: isRunning ? hrClass : 'text-gray-700',
                  border: hrZone === 'danger' ? 'border-red-900/60' : 'border-gray-800',
                },
                {
                  label: 'Temperature', value: temp.toFixed(1), unit: '°C',
                  color: isRunning ? tempClass : 'text-gray-700',
                  border: temp > 38.5 ? 'border-orange-900/60' : 'border-gray-800',
                },
                {
                  label: 'Blood Oxygen', value: `${Math.round(spo2)}`, unit: '%',
                  color: isRunning ? spo2Class : 'text-gray-700',
                  border: spo2 < 94 ? 'border-red-900/60' : 'border-gray-800',
                },
                {
                  label: 'Steps Today', value: steps.toLocaleString(), unit: '',
                  color: isRunning ? 'text-gray-300' : 'text-gray-700',
                  border: 'border-gray-800',
                },
              ].map(({ label, value, unit, color, border }) => (
                <div key={label} className={`bg-gray-900 border rounded-xl p-3.5 ${border}`}>
                  <div className={`text-2xl font-black tabular-nums ${color}`}>
                    {value}
              {/* Bluetooth Contacts */}
              <div className="premium-card p-4 flex-1 flex flex-col border-purple-50">
                <div className="flex items-center justify-between mb-3">
                  <div className="text-xs text-gray-500 font-medium">Nearby Devices ({contacts.length})</div>
                  {contacts.length > 0 && (
                    <div className="w-2 h-2 bg-blue-500 rounded-full animate-ping" />
                  )}
                </div>
                <div className="space-y-2 flex-1 overflow-y-auto min-h-[100px] scrollbar-none">1">{unit}</span>}
                  </div>
                  <div className="text-gray-600 text-xs mt-0.5">{label}</div>
                </div>
              ))}
            </div>
          </div>

          {/* Spike alert */}
          {isSpiking && (
            <div className="bg-red-950/60 border border-red-800/80 rounded-xl px-4 py-3 flex items-center gap-3">
              <div className="w-2.5 h-2.5 rounded-full bg-red-500 animate-ping flex-shrink-0" />
              <div>
                <div className="text-red-300 text-sm font-bold">Anomaly Active</div>
                <div className="text-red-400/70 text-xs">HR spike + elevated temperature · normalizing in {spikeLeft}s</div>
              </div>
            </div>
          )}

          {/* Backend assessment panel */}
          <div className={`rounded-xl border p-4 transition-all duration-500 ${
            backendAnalysis?.is_anomaly
              ? 'bg-red-950/40 border-red-800/70'
              : backendAnalysis
              ? 'bg-gray-900 border-gray-800'
              : 'bg-gray-900/40 border-gray-800/40'
          }`}>
            <div className="flex items-center justify-between mb-3">
              <div className="text-gray-500 text-[10px] font-bold uppercase tracking-widest">Backend Assessment</div>
              {backendAnalysis && (
                <span className={`text-[9px] font-bold px-2 py-0.5 rounded-full ${
                  backendAnalysis.alert_severity === 'CRITICAL' ? 'bg-red-900/60 text-red-300' :
                  backendAnalysis.alert_severity === 'HIGH'     ? 'bg-orange-900/60 text-orange-300' :
                  'bg-green-900/60 text-green-300'
                }`}>
                  {backendAnalysis.alert_severity}
                </span>
              )}
            </div>
            {backendAnalysis ? (
              <div className="space-y-2">
                <div className="grid grid-cols-2 gap-2">
                  <div className="bg-gray-800/60 rounded-lg px-3 py-2">
                    <div className="text-gray-500 text-[9px] uppercase tracking-wider mb-0.5">Risk Tier</div>
                    <div className={`text-sm font-bold ${
                      backendAnalysis.risk_tier === 'CRITICAL' ? 'text-red-400' :
                      backendAnalysis.risk_tier === 'HIGH'     ? 'text-orange-400' :
                      backendAnalysis.risk_tier === 'MODERATE' ? 'text-amber-400' :
                      'text-green-400'
                    }`}>{backendAnalysis.risk_tier}</div>
                  </div>
                  <div className="bg-gray-800/60 rounded-lg px-3 py-2">
                    <div className="text-gray-500 text-[9px] uppercase tracking-wider mb-0.5">Anomaly</div>
                    <div className={`text-sm font-bold ${backendAnalysis.is_anomaly ? 'text-red-400' : 'text-green-400'}`}>
                      {backendAnalysis.is_anomaly ? (backendAnalysis.dual_anomaly ? 'DUAL' : 'YES') : 'NONE'}
                    </div>
                  </div>
                  <div className="bg-gray-800/60 rounded-lg px-3 py-2">
                    <div className="text-gray-500 text-[9px] uppercase tracking-wider mb-0.5">Profile</div>
                    <div className="text-blue-300 text-[10px] font-medium leading-tight">{backendAnalysis.cluster}</div>
                  </div>
                  <div className="bg-gray-800/60 rounded-lg px-3 py-2">
                    <div className="text-gray-500 text-[9px] uppercase tracking-wider mb-0.5">Contacts Linked</div>
                    <div className="text-white text-sm font-bold">{backendAnalysis.nearby_contacts_registered}</div>
                  </div>
                </div>
                <div className="flex items-center gap-1.5 pt-0.5">
                  <div className="w-1.5 h-1.5 rounded-full bg-green-500 flex-shrink-0" />
                  <span className="text-gray-600 text-[10px]">Analyzed · broadcast to dashboard clients</span>
                </div>
              </div>
            ) : (
              <div className="text-gray-700 text-xs text-center py-2">
                {isRunning ? 'Awaiting first backend response…' : 'Start the simulation to receive analysis'}
            {/* ── Control Panel (Right Side) ──────────────────────────────────────── */}
        <div className="flex-1 min-w-[300px] max-w-md flex flex-col gap-6 z-10">
          
          <div className="premium-card p-6 border-blue-50">
            <h3 className="text-lg font-display font-bold mb-1 text-gray-900">Engine Controls</h3>
            <p className="text-xs text-gray-500 mb-6">Manage global scenario simulation</p>percase tracking-widest">HR History</div>
              <div className="text-gray-700 text-[10px]">last 30 s</div>
            </div>
            <svg width="100%" height={SPARK_H} viewBox={`0 0 ${SPARK_W} ${SPARK_H}`} preserveAspectRatio="none">
              <defs>
                <linearGradient id="sparkGrad" x1="0" y1="0" x2="0" y2="1">
{{ ... }}
              {contacts.length > 0 && (
                <span className="ml-2 text-blue-400 font-mono">{contacts.length} detected</span>
              )}
            </div>
            {contacts.length > 0 ? (
              <div className="flex-1 p-4 flex flex-col gap-4 overflow-y-auto scrollbar-none bg-gray-50">
              
              {/* Device ID Card */}
              <div className="premium-card p-4 flex items-center justify-between border-indigo-100">
                <div className="flex items-center gap-3">
                      <div className={`w-2 h-2 rounded-full flex-shrink-0 ${PROX_DOT[c.proximity]}`} />
                      <span className="text-white text-xs font-mono">{c.user_id}</span>
                    <div>
                    <div className="text-xs text-gray-500">Wearable ID</div>
                    <div className="font-mono text-sm font-bold text-indigo-600">{deviceMac}</div>
                  </div>
                </div>
                <div className="px-2 py-1 bg-indigo-50 text-indigo-700 rounded text-[10px] font-bold border border-indigo-100">
                  SYNCED
                </div>
                ))}
              </div>
            ) : (
              <div className="text-gray-700 text-sm text-center py-3">
                {isRunning ? 'Scanning for contacts…' : 'Start the simulation to detect contacts'}
              </div>
            )}
          </div>

          {/* Transmission log */}
          <div className="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div className="flex items-center justify-between mb-3">
              <div className="text-gray-500 text-[10px] font-bold uppercase tracking-widest">Transmission Log</div>
              {totalPings > 0 && (
                <span className="text-gray-600 text-[10px]">{totalPings} pings sent</span>
              )}
            </div>
            {pingLog.length > 0 ? (
              <div className="space-y-1">
                {pingLog.map((entry, i) => (
                  <div
                    key={i}
                    className={`text-[10px] font-mono px-2.5 py-1.5 rounded-lg ${
                      i === 0
                        ? 'bg-green-950/60 border border-green-900/60 text-green-300'
                        : 'bg-gray-800/50 text-gray-600'
                    }`}
                  >
                    {entry}
                  </div>
                ))}
              </div>
            ) : (
              <div className="text-gray-700 text-xs text-center py-3">
                No transmissions yet — start the simulation
              </div>
            )}
          </div>

          {/* How it works */}
          <div className="bg-gray-900/40 border border-gray-800/40 rounded-xl p-4 space-y-2 text-xs text-gray-600">
            <div className="text-gray-400 font-semibold text-[10px] uppercase tracking-widest mb-1">How it works</div>
            <div><span className="text-green-400 font-bold">1.</span> Click <span className="text-green-400 font-medium">▶ Start Sim</span> — vitals begin generating every second</div>
            <div><span className="text-green-400 font-bold">2.</span> Every 3 s the device pings <span className="font-mono text-blue-400">POST /api/device/ping</span> — backend analyzes vitals inline</div>
            <div><span className="text-green-400 font-bold">3.</span> Backend immediately broadcasts analyzed state to all <span className="text-red-400 font-medium">Live Mode</span> dashboard clients</div>
            <div><span className="text-green-400 font-bold">4.</span> The <span className="text-cyan-400 font-medium">Backend Assessment</span> panel above shows what the backend computed for each ping</div>
            <div><span className="text-green-400 font-bold">5.</span> Click <span className="text-orange-400 font-medium">⚡ Spike HR</span> — anomaly triggers a CRITICAL alert on the dashboard instantly</div>
          </div>
        </div>

      </main>
    </div>
  );
}
